from __future__ import annotations

from pathlib import Path
from typing import Mapping, Any

class EffectiveConfig:
    @property
    def project_name(self) -> str: ...
    @property
    def root(self) -> Path: ...
    def to_json(self) -> str: ...

class RegistryRecord:
    def __init__(self, kind: str, name: str, version: str, module: str, qualname: str, source: Path, tags: list[str] | None = None, description: str = "", metadata: str | None = None) -> None: ...
    @property
    def kind(self) -> str: ...
    @property
    def name(self) -> str: ...
    def to_json(self) -> str: ...

class Registry:
    def __init__(self) -> None: ...
    def insert(self, record: RegistryRecord) -> None: ...
    def to_json(self) -> str: ...

class Metric:
    def __init__(self, name: str, value: float, unit: str | None = None, direction: str | None = None) -> None: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> float: ...

class ResultBundle:
    def __init__(self) -> None: ...
    def to_json(self) -> str: ...

class RuntimeContext:
    def __init__(self, run_id: str | None, run_dir: Path | None) -> None: ...
    def log_metric(self, name: str, value: float) -> None: ...
    def log_metrics(self, metrics: dict[str, float]) -> None: ...
    def metrics_json(self) -> str: ...

class RunDirectory:
    def __init__(self, id: str) -> None: ...
    @property
    def id(self) -> str: ...

class ArtifactManifest:
    def to_json(self) -> str: ...

class ArtifactStore:
    def __init__(self, root: Path) -> None: ...
    def promote(self, source: Path, kind: str, name: str, version: str) -> ArtifactManifest: ...

class ProductionPolicy:
    def __init__(self, strict: bool) -> None: ...
    @property
    def strict(self) -> bool: ...

def cli_main() -> int: ...
def find_project_root(path: Path) -> Path: ...
def load_config(root: Path | None = None) -> EffectiveConfig: ...
def bundle_from_metrics(metrics: Mapping[str, float]) -> ResultBundle: ...
